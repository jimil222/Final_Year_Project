# Example environment variables file
# Copy this to .env and fill in your actual values

# REQUIRED: Cloud MySQL database connection string
# Format: mysql://user:password@host:port/database
# Example: mysql://admin:password123@mysql.example.com:3306/libra_db
DATABASE_URL=mysql://user:password@host:port/database

# Optional: JWT Secret Key (change in production!)
SECRET_KEY=your_super_secret_key_change_this_in_production

# Optional: JWT Algorithm
ALGORITHM=HS256

# Optional: Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional: Minimum time before book can be returned (seconds)
MIN_RETURN_TIME_SECONDS=10

# Optional: Frontend API URL
VITE_API_URL=http://localhost:8000
